# Copy this file to .env and fill in real values
# .env is gitignored — never commit real keys

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Pipeline limits
MAX_PAGES_PER_JOB=50

# Model weight paths (relative to backend/)
LAMA_MODEL_PATH=./models/lama/big-lama.pth
DETECTOR_MODEL_PATH=./models/comic_text_detector/comictextdetector.pt

# ── Shared Library (optional — leave blank to disable) ───────────────────────
# Supabase — https://supabase.com → New Project → Settings → API
# Use the service_role key (secret, backend only — never expose to frontend)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage API Tokens
# Create bucket "manga-chapters", enable Public Access in bucket settings
R2_ACCOUNT_ID=your_32char_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=manga-chapters
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
